@model AutoPlusMVC.Models.Car

@{
    ViewData["Title"] = "Delete";
}

<div class="container mt-4">
    <h2 class="mb-3 text-danger">Delete Car</h2>

    <p>Are you sure you want to delete this car?</p>

    <div class="card p-3 shadow-sm" style="max-width: 500px;">
        <img src="@(string.IsNullOrEmpty(Model.Image) ? "https://placehold.co/500x250?text=No+Image" : Model.Image)"
             class="card-img-top mb-3"
             alt="@Model.Make @Model.Model"
             style="height:250px; object-fit:cover;" />

        <p><strong>Make:</strong> @Model.Make</p>
        <p><strong>Model:</strong> @Model.Model</p>
        <p><strong>Year:</strong> @Model.Year</p>
        <p><strong>Price:</strong> $@Model.Price</p>
        <p><strong>VIN:</strong> @(string.IsNullOrEmpty(Model.VIN) ? "N/A" : Model.VIN)</p>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <input type="submit" value="Delete" class="btn btn-danger" />
            <a asp-action="Index" class="btn btn-secondary ms-2">Back</a>
        </form>
    </div>
</div>
@model AutoPlusMVC.Models.Car

@{
    ViewData["Title"] = "Vehicle Details";
}

<div class="container mt-4">
    <div class="card shadow-sm" style="max-width: 700px;">
        <img src="@(string.IsNullOrEmpty(Model.Image) ? "https://placehold.co/700x350?text=No+Image" : Model.Image)"
             class="card-img-top"
             alt="@Model.Make @Model.Model"
             style="height:350px; object-fit:cover;" />

        <div class="card-body">
            <h3>@Model.Year @Model.Make @Model.Model</h3>
            <p><strong>Price:</strong> $@Model.Price</p>
            <p><strong>VIN:</strong> @(string.IsNullOrEmpty(Model.VIN) ? "N/A" : Model.VIN)</p>
        </div>

        <div class="card-footer bg-white border-0">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
            <a asp-action="Index" class="btn btn-secondary">Back</a>
        </div>
    </div>
</div>
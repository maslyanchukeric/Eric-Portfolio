@model List<SportsApp2.Models.UpcomingEvents>

@{
    Layout = null;
    ViewData["Title"] = "Upcoming Events";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <title>Sports Management - Upcoming Events</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="https://www.w3schools.com/w3css/5/w3.css">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Raleway">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">

    <style>
            body, h1, h2, h3, h4, h5, h6 {
                font-family: "Raleway", sans-serif;
            }

            .topnav .search-container {
                float: right;
            }

            .topnav input[type=text] {
                padding: 6px;
                margin-top: 8px;
                font-size: 17px;
                border: none;
            }

            .topnav .search-container button {
                float: right;
                padding: 6px 10px;
                margin-top: 8px;
                margin-right: 16px;
                background: #ddd;
                font-size: 17px;
                border: none;
                cursor: pointer;
            }

                .topnav .search-container button:hover {
                    background: #ccc;
                }

            .event-card {
                background: white;
                color: black;
                padding: 10px 20px;
                border: none;
                border-radius: 50px;
                cursor: pointer;
                -webkit-appearance: none;
                transition: all 0.2s ease;
                font-family: inherit;
            }

                .event-card:hover {
                    background: #2694e1;
                    color: white;
                    transform: translateY(-1px);
                    box-shadow: 0 4px 12px rgba(0, 74, 173, 0.3);
                }

            #btnTop {
                background: #083d77;
                color: #ffffff;
                padding: 10px 20px;
                border: none;
                border-radius: 50px;
                cursor: pointer;
                display: none;
                position: fixed;
                bottom: 20px;
                right: 30px;
                z-index: 99;
                -webkit-appearance: none;
                transition: all 0.2s ease;
                font-family: inherit;
                font-weight: 700;
            }

                #btnTop:hover {
                    background: #5998c5;
                    transform: translateY(-1px);
                    box-shadow: 0 4px 12px rgba(203, 238, 243, 0.3);
                }
    </style>
</head>

<body class="w3-light-grey w3-content" style="max-width:1600px">
    <!-- Sidebar/menu -->
    <nav class="w3-sidebar w3-collapse w3-animate-left" style="z-index:3;width:300px; background-color:#e6eff9;" id="mySidebar">
        <br>
        <div class="w3-container">
            <a href="#" onclick="w3_close()" class="w3-hide-large w3-right w3-jumbo w3-padding w3-hover-grey" title="close menu">
                <i class="fa fa-remove"></i>
            </a>
            <img src="~/logo.png" alt="Logo" style="width:45%;" class="w3-round"><br><br>
                <h4><b>Sports Management</b></h4>
            </div>

            <div class="w3-bar-block">
                <a asp-controller="Home" asp-action="Page1" onclick="w3_close()" class="w3-bar-item w3-button w3-padding">
                    <i class="fa fa-th-large fa-fw w3-margin-right"></i>HOME
                </a>
                <a asp-controller="Home" asp-action="User" onclick="w3_close()" class="w3-bar-item w3-button w3-padding">
                    <i class="fa fa-user fa-fw w3-margin-right"></i>USER
                </a>
                <a asp-controller="Home" asp-action="Contact" onclick="w3_close()" class="w3-bar-item w3-button w3-padding">
                    <i class="fa fa-envelope fa-fw w3-margin-right"></i>CONTACT
                </a>
                <a asp-controller="Home" asp-action="UpcomingEventsHTML" onclick="w3_close()" class="w3-bar-item w3-button w3-padding" style="color:#2694e1;">
                    <i class="fa fa-calendar fa-fw w3-margin-right"></i>UPCOMING EVENTS
                </a>
            </div>

            <div class="w3-panel w3-large">
                <i class="fa fa-facebook-official w3-hover-opacity"></i>
                <i class="fa fa-instagram w3-hover-opacity"></i>
                <i class="fa fa-snapchat w3-hover-opacity"></i>
                <i class="fa fa-pinterest-p w3-hover-opacity"></i>
                <i class="fa fa-twitter w3-hover-opacity"></i>
                <i class="fa fa-linkedin w3-hover-opacity"></i>
            </div>
        </nav>

        <!-- Overlay effect when opening sidebar on small screens -->
        <div class="w3-overlay w3-hide-large w3-animate-opacity"
             onclick="w3_close()"
             style="cursor:pointer"
             title="close side menu"
             id="myOverlay"></div>

        <!-- PAGE CONTENT -->
        <div class="w3-main" style="margin-left:300px">
            <!-- Header -->
            <header id="SportsManagement">
                <a href="#">
                    <img src="/w3images/avatar_g2.jpg" style="width:65px;" class="w3-circle w3-right w3-margin w3-hide-large w3-hover-opacity" alt="Avatar">
                </a>
                <span class="w3-button w3-hide-large w3-xxlarge w3-hover-text-grey" onclick="w3_open()">
                    <i class="fa fa-bars"></i>
                </span>

                <div class="w3-container">
                    <h1><b>Upcoming Events</b></h1>

                    <div class="w3-section w3-bottombar w3-padding-16">
                        <span class="w3-margin-right">Filter:</span>

                        <a asp-controller="Home"
                               asp-action="UpcomingEventsHTML"
                               asp-route-category="ALL"
                               class="w3-button @((ViewBag.SelectedCategory == null || ViewBag.SelectedCategory == "ALL") ? "w3-black" : "w3-white")">
                            ALL
                        </a>

                        <a asp-controller="Home"
                               asp-action="UpcomingEventsHTML"
                               asp-route-category="NFL"
                               class="w3-button @(ViewBag.SelectedCategory == "NFL" ? "w3-black" : "w3-white")">
                            NFL
                        </a>

                        <a asp-controller="Home"
                               asp-action="UpcomingEventsHTML"
                               asp-route-category="NBA"
                               class="w3-button @(ViewBag.SelectedCategory == "NBA" ? "w3-black" : "w3-white")">
                            NBA
                        </a>

                        <input type="text" placeholder="Search.." name="search">
                        <button type="button"><i class="fa fa-search"></i></button>
                    </div>
                </div>
            </header>

            @if (Model == null || Model.Count == 0)
            {
                <div class="w3-container">
                    <p>No upcoming events found.</p>
                </div>
            }
            else
            {
                <div class="w3-container">
                    <div class="events-container">
                        @foreach (var ev in Model)
                        {
                            <div class="event-card" style="border:1px solid #ccc; padding:15px; margin-bottom:15px; border-radius:8px;">
                                <p><strong>Category:</strong> @ev.Category</p>
                                <p><strong>Date:</strong> @ev.Date.ToString("MMMM dd, yyyy")</p>
                                <p><strong>Time:</strong> @ev.Time</p>
                                <p><strong>Team 1:</strong> @ev.Team1</p>
                                <p><strong>Team 2:</strong> @ev.Team2</p>
                                <p><strong>Location:</strong> @ev.Arena</p>
                                <p><strong>Where to Listen:</strong> @ev.whereToListen</p>
                            </div>
                        }
                    </div>
                </div>
            }

            <button onclick="topFunction()" id="btnTop" title="Go to top">Back to Top</button>

            <footer>
                <div class="w3-row-padding" style="background:#011d4a; color:white;">
                    <p>
                        GAMBLING PROBLEM? CALL 1-800-GAMBLER, (800) 327-5050 or visit gamblinghelplinema.org (MA).
                        Call 877-8-HOPENY/text HOPENY (467369) (NY). Please Gamble Responsibly. 888-789-7777/visit ccpg.org (CT),
                        or visit www.mdgamblinghelp.org (MD). 21+ and present in most states. (18+ DC/KY/NH/WY). Void in ONT/OR/NH.
                        Eligibility restrictions apply. On behalf of Boot Hill Casino & Resort (KS).
                        Terms: sportsbook.draftkings.com/promos.
                    </p>

                    <p>Copyright: © 2026 Sports Application, LLC. All rights reserved.</p>
                </div>
            </footer>

            <div class="w3-row-padding" style="background:black; color:white;">
                <h5>Author: Sports Application</h5>
                <p><a href="mailto:sportsapplication206@gmail.com">sportsapplication206@gmail.com</a></p>
                <p>Copyright: © 2026 Sports Application, LLC. All rights reserved.</p>
            </div>
        </div>

        <script>
                function w3_open() {
                    document.getElementById("mySidebar").style.display = "block";
                    document.getElementById("myOverlay").style.display = "block";
                }

                function w3_close() {
                    document.getElementById("mySidebar").style.display = "none";
                    document.getElementById("myOverlay").style.display = "none";
                }
        </script>

        <script>
                let mybutton = document.getElementById("btnTop");

                window.onscroll = function () { scrollFunction(); };

                function scrollFunction() {
                    if (document.body.scrollTop > 20 || document.documentElement.scrollTop > 20) {
                        mybutton.style.display = "block";
                    } else {
                        mybutton.style.display = "none";
                    }
                }

                function topFunction() {
                    document.body.scrollTop = 0;
                    document.documentElement.scrollTop = 0;
                }
        </script>
    </body>
</html>